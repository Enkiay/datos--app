{
  "version": "2.0",
  "plantillas": [
    {
      "id": "cerramiento-perimetral",
      "nombre": "Cerramiento Perimetral",
      "descripcion": "Estructura completa: excavación, H° pobre, cimiento, sobrecimiento, zapatas, columnas, viga de amarre y muro de ladrillo 6H.",
      "inputsRequeridos": [
        {
          "nombre": "longitud_total",
          "label": "Longitud total del muro",
          "unidad": "m",
          "default": 0.0
        },
        {
          "nombre": "altura_muro",
          "label": "Altura del muro",
          "unidad": "m",
          "default": 2.5
        }
      ],
      "parametrosEditables": [
        {
          "nombre": "separacion_columnas",
          "label": "Separación entre columnas",
          "unidad": "m",
          "default": 4.0,
          "min": 2.0,
          "max": 6.0
        },
        {
          "nombre": "sec_columna",
          "label": "Lado sección columna",
          "unidad": "m",
          "default": 0.20,
          "min": 0.15,
          "max": 0.40
        },
        {
          "nombre": "ancho_zapata",
          "label": "Ancho zapata",
          "unidad": "m",
          "default": 0.40,
          "min": 0.30,
          "max": 0.80
        },
        {
          "nombre": "espesor_zapata",
          "label": "Espesor zapata",
          "unidad": "m",
          "default": 0.30,
          "min": 0.20,
          "max": 0.60
        },
        {
          "nombre": "prof_excavacion",
          "label": "Profundidad excavación",
          "unidad": "m",
          "default": 0.60,
          "min": 0.40,
          "max": 1.00
        },
        {
          "nombre": "ancho_cimiento",
          "label": "Ancho cimiento corrido",
          "unidad": "m",
          "default": 0.40,
          "min": 0.30,
          "max": 0.60
        },
        {
          "nombre": "h_cimiento",
          "label": "Altura cimiento corrido",
          "unidad": "m",
          "default": 0.40,
          "min": 0.30,
          "max": 0.60
        },
        {
          "nombre": "espesor_hp",
          "label": "Espesor H° pobre",
          "unidad": "m",
          "default": 0.05,
          "min": 0.03,
          "max": 0.10
        },
        {
          "nombre": "ancho_sobrecimiento",
          "label": "Ancho sobrecimiento",
          "unidad": "m",
          "default": 0.20,
          "min": 0.15,
          "max": 0.30
        },
        {
          "nombre": "h_sobrecimiento",
          "label": "Altura sobrecimiento",
          "unidad": "m",
          "default": 0.30,
          "min": 0.20,
          "max": 0.60
        },
        {
          "nombre": "sec_viga",
          "label": "Ancho viga de amarre",
          "unidad": "m",
          "default": 0.20,
          "min": 0.15,
          "max": 0.30
        },
        {
          "nombre": "h_viga",
          "label": "Altura viga de amarre",
          "unidad": "m",
          "default": 0.20,
          "min": 0.15,
          "max": 0.40
        }
      ],
      "items": [
        {
          "id": "excavacion",
          "nombre": "Excavación de zanjas",
          "unidad": "m3",
          "formulaTexto": "longitud_total * ancho_cimiento * prof_excavacion",
          "lee": ["longitud_total", "ancho_cimiento", "prof_excavacion"],
          "escribe": "vol_excavacion",
          "catalogoCodigo": "UH002"
        },
        {
          "id": "hp_capa",
          "nombre": "Capa de hormigón pobre",
          "unidad": "m3",
          "formulaTexto": "longitud_total * ancho_cimiento * espesor_hp",
          "lee": ["longitud_total", "ancho_cimiento", "espesor_hp"],
          "escribe": "vol_hp",
          "catalogoCodigo": "UH003"
        },
        {
          "id": "cimiento",
          "nombre": "Cimiento corrido",
          "unidad": "m3",
          "formulaTexto": "longitud_total * ancho_cimiento * h_cimiento",
          "lee": ["longitud_total", "ancho_cimiento", "h_cimiento"],
          "escribe": "vol_cimiento",
          "catalogoCodigo": "UH004"
        },
        {
          "id": "sobrecimiento",
          "nombre": "Sobrecimiento",
          "unidad": "m3",
          "formulaTexto": "longitud_total * ancho_sobrecimiento * h_sobrecimiento",
          "lee": ["longitud_total", "ancho_sobrecimiento", "h_sobrecimiento"],
          "escribe": "vol_sobrecimiento",
          "catalogoCodigo": "UH005"
        },
        {
          "id": "zapatas",
          "nombre": "Zapata de H°A°",
          "unidad": "m3",
          "formulaTexto": "ceil(longitud_total / separacion_columnas) * ancho_zapata * ancho_zapata * espesor_zapata",
          "lee": ["longitud_total", "separacion_columnas", "ancho_zapata", "espesor_zapata"],
          "escribe": "vol_zapatas",
          "catalogoCodigo": "UH006"
        },
        {
          "id": "columnas",
          "nombre": "Columna de H°A°",
          "unidad": "m3",
          "formulaTexto": "ceil(longitud_total / separacion_columnas) * sec_columna * sec_columna * (altura_muro + h_sobrecimiento)",
          "lee": ["longitud_total", "separacion_columnas", "sec_columna", "altura_muro", "h_sobrecimiento"],
          "escribe": "vol_columnas",
          "catalogoCodigo": "UH007"
        },
        {
          "id": "viga_amarre",
          "nombre": "Viga de amarre superior",
          "unidad": "m3",
          "formulaTexto": "longitud_total * sec_viga * h_viga",
          "lee": ["longitud_total", "sec_viga", "h_viga"],
          "escribe": "vol_viga",
          "catalogoCodigo": "UH008"
        },
        {
          "id": "muro",
          "nombre": "Muro de ladrillo 6H",
          "unidad": "m2",
          "formulaTexto": "longitud_total * altura_muro - ceil(longitud_total / separacion_columnas) * sec_columna * altura_muro",
          "lee": ["longitud_total", "altura_muro", "separacion_columnas", "sec_columna"],
          "escribe": "area_muro",
          "catalogoCodigo": "UH009"
        }
      ],
      "aceroConfig": {
        "diametroLongitudinal": 10.0,
        "diametroEstribo": 6.0,
        "barrasPorColumna": 4,
        "separacionEstribos": 0.20,
        "recubrimiento": 0.025,
        "doblez": 0.20,
        "ganchoEstribo": 0.06,
        "longitudBarraComercial": 6.0
      },
      "zapataAceroConfig": {
        "diametro": 10.0,
        "separacion": 0.10,
        "recubrimiento": 0.02,
        "doblez": 0.20,
        "longitudBarraComercial": 6.0
      }
    }
  ]
}
