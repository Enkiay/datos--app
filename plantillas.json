{
  "version": "2.0",
  "plantillas": [
    {
      "id": "cerramiento-perimetral",
      "nombre": "Cerramiento Perimetral",
      "descripcion": "Estructura completa: excavación, H° pobre, cimiento, sobrecimiento, zapatas, columnas, viga de amarre y muro de ladrillo 6H.",
      "inputsRequeridos": [
        {
          "nombre": "longitud_total",
          "label": "Longitud total del muro",
          "unidad": "m",
          "default": 0.0
        },
        {
          "nombre": "altura_muro",
          "label": "Altura del muro",
          "unidad": "m",
          "default": 2.5
        }
      ],
      "parametrosEditables": [
        {
          "nombre": "separacion_columnas",
          "label": "Separación entre columnas",
          "unidad": "m",
          "default": 4.0,
          "min": 2.0,
          "max": 6.0
        },
        {
          "nombre": "sec_columna",
          "label": "Lado sección columna",
          "unidad": "m",
          "default": 0.20,
          "min": 0.15,
          "max": 0.40
        },
        {
          "nombre": "h_sobrecimiento",
          "label": "Altura sobrecimiento",
          "unidad": "m",
          "default": 0.30,
          "min": 0.20,
          "max": 0.60
        }
      ],
      "items": [
        {
          "id": "excavacion",
          "nombre": "Excavación de zanjas",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": ["longitud_total"],
          "escribe": "ml_excavacion",
          "catalogoCodigo": "UH002",
          "presetNombre": "40\u00d760"
        },
        {
          "id": "hp_capa",
          "nombre": "Capa de hormigón pobre",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": ["longitud_total"],
          "escribe": "ml_hp",
          "catalogoCodigo": "UH003",
          "presetNombre": "40\u00d75cm"
        },
        {
          "id": "cimiento",
          "nombre": "Cimiento corrido",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": ["longitud_total"],
          "escribe": "ml_cimiento",
          "catalogoCodigo": "UH004",
          "presetNombre": "40\u00d740"
        },
        {
          "id": "sobrecimiento",
          "nombre": "Sobrecimiento",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": ["longitud_total"],
          "escribe": "ml_sobrecimiento",
          "catalogoCodigo": "UH005",
          "presetNombre": "20\u00d730"
        },
        {
          "id": "zapatas",
          "nombre": "Zapata de H°A°",
          "unidad": "m3",
          "formulaTexto": "ceil(longitud_total / separacion_columnas)",
          "lee": ["longitud_total", "separacion_columnas"],
          "escribe": "cant_zapatas",
          "catalogoCodigo": "UH006",
          "presetNombre": "40\u00d740\u00d730"
        },
        {
          "id": "columnas",
          "nombre": "Columna de H°A°",
          "unidad": "m3",
          "formulaTexto": "ceil(longitud_total / separacion_columnas) * (altura_muro + h_sobrecimiento)",
          "lee": ["longitud_total", "separacion_columnas", "altura_muro", "h_sobrecimiento"],
          "escribe": "vol_columnas",
          "catalogoCodigo": "UH007",
          "presetNombre": "20\u00d720"
        },
        {
          "id": "viga_amarre",
          "nombre": "Viga de amarre superior",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": ["longitud_total"],
          "escribe": "ml_viga",
          "catalogoCodigo": "UH008",
          "presetNombre": "20\u00d720"
        },
        {
          "id": "muro",
          "nombre": "Muro de ladrillo 6H",
          "unidad": "m2",
          "formulaTexto": "longitud_total * altura_muro - ceil(longitud_total / separacion_columnas) * sec_columna * altura_muro",
          "lee": ["longitud_total", "altura_muro", "separacion_columnas", "sec_columna"],
          "escribe": "area_muro",
          "catalogoCodigo": "UH009"
        }
      ],
      "aceroConfig": {
        "diametroLongitudinal": 10.0,
        "diametroEstribo": 6.0,
        "barrasPorColumna": 4,
        "separacionEstribos": 0.20,
        "recubrimiento": 0.025,
        "doblez": 0.20,
        "ganchoEstribo": 0.06,
        "longitudBarraComercial": 6.0
      },
      "zapataAceroConfig": {
        "diametro": 10.0,
        "separacion": 0.10,
        "recubrimiento": 0.02,
        "doblez": 0.20,
        "longitudBarraComercial": 6.0
      }
    }
  ]
}
