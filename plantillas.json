{
  "version": "3.0",
  "plantillas": [
    {
      "id": "cerramiento-perimetral",
      "nombre": "Cerramiento Perimetral",
      "descripcion": "Muro perimetral de ladrillo de 6 huecos sobre cimiento corrido de H°C°. Incluye excavación de zanjas (40×60 cm), capa de hormigón pobre (40×5 cm), cimiento corrido (40×40 cm), sobrecimiento (20×30 cm), zapatas de H°A° (40×40×30 cm), columnas de H°A° (20×20 cm) con viga de amarre superior (20×20 cm). La altura de columnas se calcula automáticamente sumando la altura del muro más el sobrecimiento. Separación entre columnas configurable (2 a 6 m, default 4 m). El número de esquinas descuenta el solapamiento en las intersecciones de elementos lineales (default 4 para perímetro rectangular).",
      "inputsRequeridos": [
        {
          "nombre": "longitud_total",
          "label": "Longitud total del muro",
          "unidad": "m",
          "default": 0.0
        },
        {
          "nombre": "altura_muro",
          "label": "Altura del muro",
          "unidad": "m",
          "default": 2.5
        },
        {
          "nombre": "numero_esquinas",
          "label": "Número de esquinas",
          "unidad": "und",
          "default": 4.0,
          "min": 0.0
        }
      ],
      "parametrosEditables": [
        {
          "nombre": "separacion_columnas",
          "label": "Separación entre columnas",
          "unidad": "m",
          "default": 4.0,
          "min": 2.0,
          "max": 6.0
        },
        {
          "nombre": "h_sobrecimiento",
          "label": "Altura sobrecimiento",
          "unidad": "m",
          "default": 0.3,
          "min": 0.2,
          "max": 0.6
        }
      ],
      "items": [
        {
          "id": "columnas",
          "nombre": "Columna de H°A°",
          "unidad": "m3",
          "formulaTexto": "ceil(longitud_total / separacion_columnas)",
          "lee": [
            "longitud_total",
            "separacion_columnas",
            "altura_muro",
            "h_sobrecimiento"
          ],
          "escribe": "cantidad_columnas",
          "catalogoCodigo": "UH007",
          "presetNombre": "20×20",
          "computedOverrides": {
            "altura": "altura_muro + h_sobrecimiento"
          }
        },
        {
          "id": "excavacion",
          "nombre": "Excavación de zanjas",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": [
            "longitud_total",
            "numero_esquinas"
          ],
          "escribe": "ml_excavacion",
          "catalogoCodigo": "UH002",
          "presetNombre": "40×60",
          "descuentos": [
            {
              "nombre": "Esquinas",
              "factorFormula": "numero_esquinas",
              "overrides": {
                "largo": "0.40"
              }
            }
          ]
        },
        {
          "id": "exc_zapatas",
          "nombre": "Excavación para zapatas",
          "unidad": "m3",
          "formulaTexto": "cantidad_columnas",
          "lee": [
            "cantidad_columnas"
          ],
          "escribe": "cant_exc_zapatas",
          "catalogoCodigo": "UH002",
          "parametrosItem": {
            "largo": 0.4,
            "ancho": 0.4,
            "profundidad": 0.3
          }
        },
        {
          "id": "hp_capa",
          "nombre": "Capa de hormigón pobre",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": [
            "longitud_total",
            "numero_esquinas"
          ],
          "escribe": "ml_hp",
          "catalogoCodigo": "UH003",
          "presetNombre": "40×5cm",
          "descuentos": [
            {
              "nombre": "Esquinas",
              "factorFormula": "numero_esquinas",
              "overrides": {
                "largo": "0.40"
              }
            }
          ]
        },
        {
          "id": "cimiento",
          "nombre": "Cimiento corrido",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": [
            "longitud_total",
            "numero_esquinas"
          ],
          "escribe": "ml_cimiento",
          "catalogoCodigo": "UH004",
          "presetNombre": "40×40",
          "descuentos": [
            {
              "nombre": "Esquinas",
              "factorFormula": "numero_esquinas",
              "overrides": {
                "largo": "0.40"
              }
            }
          ]
        },
        {
          "id": "sobrecimiento",
          "nombre": "Sobrecimiento",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": [
            "longitud_total",
            "numero_esquinas"
          ],
          "escribe": "ml_sobrecimiento",
          "catalogoCodigo": "UH005",
          "presetNombre": "20×30",
          "computedOverrides": {
            "altura": "h_sobrecimiento"
          },
          "descuentos": [
            {
              "nombre": "Esquinas",
              "factorFormula": "numero_esquinas",
              "overrides": {
                "largo": "0.20"
              }
            }
          ]
        },
        {
          "id": "zapatas",
          "nombre": "Zapata de H°A°",
          "unidad": "m3",
          "formulaTexto": "cantidad_columnas",
          "lee": [
            "cantidad_columnas"
          ],
          "escribe": "cantidad_zapatas",
          "catalogoCodigo": "UH006",
          "presetNombre": "40×40×30"
        },
        {
          "id": "viga_amarre",
          "nombre": "Viga de amarre superior",
          "unidad": "m3",
          "formulaTexto": "longitud_total",
          "lee": [
            "longitud_total",
            "numero_esquinas"
          ],
          "escribe": "ml_viga",
          "catalogoCodigo": "UH008",
          "presetNombre": "20×20",
          "descuentos": [
            {
              "nombre": "Esquinas",
              "factorFormula": "numero_esquinas",
              "overrides": {
                "largo": "0.20"
              }
            }
          ]
        },
        {
          "id": "muro",
          "nombre": "Muro de ladrillo 6H",
          "unidad": "m2",
          "formulaTexto": "longitud_total * altura_muro",
          "lee": [
            "longitud_total",
            "altura_muro",
            "cantidad_columnas"
          ],
          "escribe": "area_muro",
          "catalogoCodigo": "UH009",
          "descuentos": [
            {
              "nombre": "Columnas",
              "factorFormula": "cantidad_columnas",
              "overrides": {
                "largo": "0.20",
                "ancho": "altura_muro"
              }
            }
          ]
        }
      ],
      "aceroConfig": {
        "diametroLongitudinal": 10.0,
        "diametroEstribo": 6.0,
        "barrasPorColumna": 4,
        "separacionEstribos": 0.2,
        "recubrimiento": 0.025,
        "doblez": 0.2,
        "ganchoEstribo": 0.06,
        "longitudBarraComercial": 6.0
      },
      "zapataAceroConfig": {
        "diametro": 10.0,
        "separacion": 0.1,
        "recubrimiento": 0.02,
        "doblez": 0.2,
        "longitudBarraComercial": 6.0
      }
    }
  ]
}