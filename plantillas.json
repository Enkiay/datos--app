{
  "version": "2.0",
  "plantillas": [
    {
      "id": "cerramiento-perimetral",
      "nombre": "Cerramiento Perimetral",
      "descripcion": "Columnas, vigas de encadenado, sobrecimiento y muro de ladrillo 6H (12 cm). Incluye zapatas y excavación.",
      "inputsRequeridos": [
        {
          "nombre": "largo",
          "label": "Largo del terreno",
          "unidad": "m",
          "default": 20.0
        },
        {
          "nombre": "ancho",
          "label": "Ancho del terreno",
          "unidad": "m",
          "default": 10.0
        },
        {
          "nombre": "altura",
          "label": "Altura del muro",
          "unidad": "m",
          "default": 2.5
        }
      ],
      "parametrosEditables": [
        {
          "nombre": "sep_columnas",
          "label": "Separación entre columnas",
          "unidad": "m",
          "default": 3.0,
          "min": 2.0,
          "max": 5.0
        },
        {
          "nombre": "sec_columna",
          "label": "Sección de columna",
          "unidad": "m",
          "default": 0.2,
          "min": 0.15,
          "max": 0.4
        },
        {
          "nombre": "sec_viga",
          "label": "Sección viga encadenado",
          "unidad": "m",
          "default": 0.2,
          "min": 0.15,
          "max": 0.3
        },
        {
          "nombre": "h_viga",
          "label": "Altura viga encadenado",
          "unidad": "m",
          "default": 0.2,
          "min": 0.15,
          "max": 0.4
        },
        {
          "nombre": "prof_zapata",
          "label": "Profundidad zapata",
          "unidad": "m",
          "default": 0.3,
          "min": 0.2,
          "max": 0.6
        },
        {
          "nombre": "ancho_zapata",
          "label": "Ancho zapata",
          "unidad": "m",
          "default": 0.4,
          "min": 0.3,
          "max": 0.8
        },
        {
          "nombre": "h_sobrecimiento",
          "label": "Altura sobrecimiento",
          "unidad": "m",
          "default": 0.3,
          "min": 0.2,
          "max": 0.6
        },
        {
          "nombre": "ancho_sobrecimiento",
          "label": "Ancho sobrecimiento",
          "unidad": "m",
          "default": 0.2,
          "min": 0.15,
          "max": 0.3
        }
      ],
      "items": [
        {
          "id": "excavacion",
          "nombre": "Excavación para zapatas",
          "unidad": "m3",
          "formulaTexto": "n_columnas * ancho_zapata * ancho_zapata * prof_zapata",
          "lee": [
            "n_columnas",
            "ancho_zapata",
            "prof_zapata"
          ],
          "escribe": "vol_excavacion",
          "catalogoCodigo": "EX010"
        },
        {
          "id": "zapatas",
          "nombre": "Zapatas de H°A°",
          "unidad": "m3",
          "formulaTexto": "n_columnas * ancho_zapata * ancho_zapata * prof_zapata",
          "lee": [
            "n_columnas",
            "ancho_zapata",
            "prof_zapata"
          ],
          "escribe": "vol_zapatas",
          "catalogoCodigo": "Z010"
        },
        {
          "id": "columnas",
          "nombre": "Columnas de H°A°",
          "unidad": "m3",
          "formulaTexto": "n_columnas * sec_columna * sec_columna * altura",
          "lee": [
            "n_columnas",
            "sec_columna",
            "altura"
          ],
          "escribe": "vol_columnas",
          "catalogoCodigo": "C100"
        },
        {
          "id": "sobrecimiento",
          "nombre": "Sobrecimiento de H°C°",
          "unidad": "m3",
          "formulaTexto": "perimetro * ancho_sobrecimiento * h_sobrecimiento",
          "lee": [
            "perimetro",
            "ancho_sobrecimiento",
            "h_sobrecimiento"
          ],
          "escribe": "vol_sobrecimiento",
          "catalogoCodigo": "S010"
        },
        {
          "id": "viga_enc",
          "nombre": "Viga de Encadenado de H°A°",
          "unidad": "m3",
          "formulaTexto": "perimetro * sec_viga * h_viga",
          "lee": [
            "perimetro",
            "sec_viga",
            "h_viga"
          ],
          "escribe": "vol_viga_enc",
          "catalogoCodigo": "V010"
        },
        {
          "id": "muro",
          "nombre": "Muro de Ladrillo 6H (12 cm)",
          "unidad": "m2",
          "formulaTexto": "perimetro * altura - n_columnas * sec_columna * altura",
          "lee": [
            "perimetro",
            "altura",
            "n_columnas",
            "sec_columna"
          ],
          "escribe": "area_muro",
          "catalogoCodigo": "M050"
        }
      ],
      "aceroConfig": {
        "diametroLongitudinal": 10.0,
        "diametroEstribo": 6.0,
        "barrasPorColumna": 4,
        "separacionEstribos": 0.2,
        "recubrimiento": 0.025,
        "doblez": 0.2,
        "ganchoEstribo": 0.06,
        "longitudBarraComercial": 6.0
      },
      "zapataAceroConfig": {
        "diametro": 10.0,
        "separacion": 0.1,
        "recubrimiento": 0.02,
        "doblez": 0.2,
        "longitudBarraComercial": 6.0
      }
    }
  ]
}